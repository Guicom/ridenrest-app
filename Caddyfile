{
  email {$ACME_EMAIL}
}

ridenrest.app {
  # Plausible reverse proxy (bypass ad blockers — story 15.6)
  handle /js/script* {
    reverse_proxy plausible:8000 {
      header_up Host stats.ridenrest.app
      transport http {
        versions 1.1
      }
    }
  }

  handle /api/event {
    reverse_proxy plausible:8000 {
      header_up Host stats.ridenrest.app
      transport http {
        versions 1.1
      }
    }
  }

  reverse_proxy host.docker.internal:3011
  header {
    X-Frame-Options DENY
    X-Content-Type-Options nosniff
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}

api.ridenrest.app {
  reverse_proxy host.docker.internal:3010
  header {
    X-Frame-Options DENY
    X-Content-Type-Options nosniff
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}

stats.ridenrest.app {
  reverse_proxy plausible:8000 {
    transport http {
      versions 1.1
    }
  }
  header {
    X-Frame-Options DENY
    X-Content-Type-Options nosniff
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}

status.ridenrest.app {
  basic_auth {
    {$STATUS_USER} {$STATUS_HASHED_PASSWORD}
  }
  reverse_proxy uptime-kuma:3001
  header {
    X-Frame-Options DENY
    X-Content-Type-Options nosniff
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}
