{
  "extends": "@ridenrest/typescript-config/nextjs",
  "compilerOptions": {
    "noEmit": true,
    "isolatedModules": true,
    "lib": ["dom", "dom.iterable", "ES2022"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["@testing-library/jest-dom"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
