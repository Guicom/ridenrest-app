# NestJS API — Environment Variables

# Database (Aiven PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Redis (Upstash — use rediss:// for TLS)
REDIS_URL=rediss://:password@hostname:6379

# Upstash alert set at 7500 cmds/day (75% of 10k quota)
# Configure in Upstash console: Redis database → Alerts → Daily Commands → 7500 → email

# Port (optional — defaults to 3010)
PORT=3010
